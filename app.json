{
  "expo": {
    "name": "Maal Solutions",
    "slug": "maalex",
    "version": "10.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
